# Klucze i sekrety
.env

# Dane (cache pobrań i artefakty obliczeniowe — duże, regenerowalne)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
outputs/*
!outputs/.gitkeep
!outputs/figures/.gitkeep
outputs/figures/*
!outputs/figures/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# IDE
.idea/
.vscode/
